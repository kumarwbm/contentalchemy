# ── LLM Providers ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...       # optional fallback
GOOGLE_API_KEY=...                 # optional fallback

# ── Research ────────────────────────────────────────────────────
SERP_API_KEY=...

# ── Image Generation ────────────────────────────────────────────
# DALL-E 3 uses your OPENAI_API_KEY above — no extra key needed

# ── App Settings ────────────────────────────────────────────────
PRIMARY_LLM=gpt-4o
FALLBACK_LLM=gpt-4o-mini
IMAGE_MODEL=dall-e-3
IMAGE_FALLBACK_MODEL=dall-e-2
RESEARCH_CACHE_TTL=1800            # seconds (30 min)
MAX_SEARCH_RESULTS=10

# ── LangSmith (optional — for tracing) ──────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=contentalchemy

# ── Streamlit ───────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
